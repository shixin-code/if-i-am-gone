# 复制为 .env 并填入真实值。.env 已被 .gitignore 忽略，绝不入库。
# config.yaml 中的 ${VAR} 占位符会从这些环境变量展开。

# Telegram Bot —— 找 @BotFather 创建 bot 获取 token
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# SMTP 授权码（多数邮箱用「授权码」而非登录密码）
SMTP_PASSWORD=your-smtp-app-password

# state 中加密包密码字段的主口令（迭代2 启用；仅存于此，不落盘到 state.db）
MASTER_PASSPHRASE=change-me-to-a-long-random-passphrase

# 对象存储凭据（迭代3，download.mode=s3 时才需要）
S3_ACCESS_KEY=
S3_SECRET_KEY=
